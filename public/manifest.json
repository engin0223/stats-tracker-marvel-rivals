{
  "manifest_version": 1,
  "UID": "marvel-rivals-healing-tracker-dev-local",
  "type": "WebApp",
  "meta": {
    "name": "Marvel Rivals Healing Tracker",
    "version": "1.0.0",
    "minimum-overwolf-version": "0.200.0.0",
    "author": "Developer",
    "description": "Healing tracker overlay for Marvel Rivals",
    "icon": "icon.png",
    "icon_gray": "icon_gray.png"
  },
  "data": {
    "start_window": "overlay",
    "windows": {
      "overlay": {
        "file": "index.html",
        "transparent": true,
        "resizable": false,
        "use_os_windowing": true,
        "show_in_taskbar": false,
        "size": {
          "width": 300,
          "height": 150
        },
        "in_game_only": true,
        "grab_keyboard_focus": false
      }
    },
    "hotkeys": {
      "toggle_timer": {
        "title": "Toggle Timer",
        "action-type": "custom",
        "default": "Shift+Plus"
      },
      "reset_stats": {
        "title": "Reset Stats",
        "action-type": "custom",
        "default": "Shift+Minus"
      },
      "toggle_edit": {
        "title": "Toggle Edit Mode",
        "action-type": "custom",
        "default": "Shift+8"
      }
    }
  }
}