{
  "manifest_version": 1,
  "UID": "marvel-rivals-healing-tracker-dev-local",
  "type": "WebApp",
  "meta": {
    "name": "Marvel Rivals Healing Tracker",
    "version": "1.0.0",
    "description": "Tracks match stats for Marvel Rivals",
    "minimum-overwolf-version": "0.200.0.0",
    "author": "Developer",
    "icon": "icon.png",
    "icon_gray": "icon_gray.png"
  },
  "permissions": [
    "GameInfo",
    "Hotkeys",
    "game_events"
  ],
  "game_events": {
      "ids": [24890], 
      "features": ["gep_internal", "match_info", "game_info"]
  },
  "data": {
    "start_window": "background",
    "windows": {
      "background": {
        "file": "background.html",
        "is_background_page": true
      },
      "overlay": {
        "file": "index.html",
        "transparent": true,
        "resizable": false,
        "use_os_windowing": true,
        "size": {
          "width": 300,
          "height": 250
        },
        "topmost": true
      }
    },
    "hotkeys": {
      "toggle_edit": {
        "title": "Toggle Tracker Edit Mode",
        "action-type": "custom",
        "default": "Shift+8"
      }
    }
  }
}